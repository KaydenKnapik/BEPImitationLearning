    <mxCell id="17" value="<b>Isaac Sim Scene</b>" style="swimlane;startSize=28;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;whiteSpace=wrap;html=1;" vertex="1" edge="0" parent="1">
